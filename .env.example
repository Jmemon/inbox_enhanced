# Postgres connection. On Railway this is provided by the Postgres plugin as DATABASE_URL.
DATABASE_URL=postgresql+psycopg://inbox:inbox@localhost:5432/inbox

# Random urlsafe string used to sign the OAuth state cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-me

# Fernet key for encrypting stored Gmail tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DO NOT rotate casually — rotating strands every stored refresh token.
ENCRYPTION_KEY=replace-me

# Session cookie TTL in seconds. Default 30 days.
SESSION_TTL_SECONDS=2592000

# Google OAuth credentials from console.cloud.google.com -> Credentials -> OAuth 2.0 Client (Web).
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
# Public URL of /auth/callback. Locally: http://localhost:8000/auth/callback. On Railway:
#   https://<your-app>.up.railway.app/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Only set on a real custom domain. Leave UNSET on Railway-issued *.up.railway.app hosts.
# COOKIE_DOMAIN=

# Redis URL. Used as celery broker, celery result backend, active-user registry,
# and per-user pub/sub bus. Locally docker-compose exposes 6379. Railway provides
# REDIS_URL automatically when you add the Redis plugin.
REDIS_URL=redis://localhost:6379/0

# OpenRouter — LLM classifier (OpenAI-compatible API; swappable model)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Provider-prefixed model id (e.g. anthropic/claude-haiku-4-5, openai/gpt-4o-mini)
LLM_CLASSIFY_MODEL=anthropic/claude-haiku-4-5
# Model used for the task-extraction LLM stage (Phase 2A task engine); kept
# separate from LLM_CLASSIFY_MODEL so extraction cost/quality can be tuned
# independently.
LLM_EXTRACT_MODEL=anthropic/claude-sonnet-4.5
LLM_CONCURRENCY=16

# Minimum extraction confidence (0-100) to auto-apply an extracted task
# without user confirmation.
TASK_APPLY_CONFIDENCE=75
# Minimum confidence (0-100) to auto-link an extracted task to an existing
# thread/task rather than creating a new one.
TASK_LINK_CONFIDENCE=60
